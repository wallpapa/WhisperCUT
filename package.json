{
  "name": "whispercut",
  "version": "2.0.0",
  "description": "AI-native vertical video factory — MCP server for Claude Cowork. No UI. 10 tools: video factory (Whisper+FFmpeg) + style cloner (Gemini). 9:16 only.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/mcp/server.ts",
    "build": "tsc",
    "start": "node dist/mcp/server.js",
    "mcp": "tsx src/mcp/server.ts",
    "memory-update": "tsx src/p2p/memory-cron.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.2.14",
    "@google/genai": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "ai": "^4.3.16",
    "dotenv": "^17.4.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "whispercut",
    "ai-native",
    "video-editor",
    "mcp",
    "claude-cowork",
    "tiktok",
