    "texts": [
      {
        "id": "39761fa7-2e3d-4f5b-a3dd-971e33a61618",
        "type": "text",
        "content": "{\"text\":\"ทำไมเด็กที่เกิดมาส่วนยายน่าตาจะเหมือนพ่อมากกว่ามแม่\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      },
      {
        "id": "3b3b8fc0-93e5-465a-8bf9-35858f2d6415",
        "type": "text",
        "content": "{\"text\":\"ตั้งท่านรูกมากกาลเดือน ท่านก็คลุกร่อออกมาก\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      },
      {
        "id": "789f0011-38d8-4193-ad36-53d1a420a030",
        "type": "text",
        "content": "{\"text\":\"มีแต่คนถ้าว่า อืมมั้นพ่อมีเหมือนแม่เลย\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      },
      {
        "id": "8c598eed-6d3e-490f-951c-3dac22edd90d",
        "type": "text",
        "content": "{\"text\":\"ลูกคนเนี่ยเป็นลูกของฉันแน่นอน\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      },
      {
        "id": "b3839e69-85a7-4247-8961-2a07ed1e571e",
        "type": "text",
        "content": "{\"text\":\"ก็เกิดความพูกผ่านกัน\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      },
      {
        "id": "950a82ed-4326-46a7-911c-9e4860738156",
        "type": "text",
        "content": "{\"text\":\"คือยอมหลับว่าเฮืนเป็นลูกฉัน\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
      }
    ],
