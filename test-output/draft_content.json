        "content": "{\"text\":\"ทำไมลูกหน้าตาเหมือนพ่อมากกว่าแม่\",\"styles\":[{\"font\":{\"id\":\"\",\"path\":\"\"},\"size\":22,\"color\":\"#FFFFFFFF\",\"bold\":false,\"italic\":false}]}"
