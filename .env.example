# ══════════════════════════════════════════════════════════════════
# WhisperCUT — BYOK (Bring Your Own Key) Configuration
# ══════════════════════════════════════════════════════════════════

# ── AI Provider (เลือก 1 แบบ — ใส่ key ของตัวเอง) ─────────────────
#
# แบบ A: Gemini Free (แนะนำ — 250 req/day ฟรี)
#   สมัครที่ https://aistudio.google.com/apikey
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=your-gemini-api-key
#
# แบบ B: OpenRouter Free Models
#   สมัครที่ https://openrouter.ai/keys
# AI_PROVIDER=openrouter
# AI_MODEL=google/gemma-3-27b-it:free
# AI_API_KEY=sk-or-v1-your-key
#
# แบบ C: Ollama (Local — ไม่เสียเงิน)
#   ติดตั้ง: brew install ollama && ollama pull gemma3:27b
# AI_PROVIDER=ollama
# AI_MODEL=gemma3:27b
# AI_BASE_URL=http://localhost:11434/v1
#
# แบบ D: GLM / Custom API (any OpenAI-compatible)
# AI_PROVIDER=custom
# AI_MODEL=glm-4-flash
# AI_API_KEY=your-key
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Legacy keys (ยังใช้ได้ — ถ้าไม่ตั้ง AI_PROVIDER ระบบจะ auto-detect)
# GEMINI_API_KEY=your-gemini-api-key
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── MiniMax TTS — Dr.Gwang Cloned Voice ───────────────────────────
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id
MINIMAX_VOICE_ID=Dr.Gwang

# ── Supabase (coordinator DB) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── WhisperCUT User Token ─────────────────────────────────────────
WHISPERCUT_USER_EMAIL=your-email@example.com
WHISPERCUT_API_TOKEN=wcut_your-token-here

# ── Social Publishing ─────────────────────────────────────────────
TIKTOK_SESSION_ID=your-session-id
TIKTOK_ACCOUNT_ID=your-tiktok-account-id
IG_ACCOUNT_ID=your-instagram-account-id
FB_PAGE_ID=your-facebook-page-id
YT_CHANNEL_ID=your-youtube-channel-id
YT_PROJECT_IDS=your-gcp-project-1,your-gcp-project-2

# ── Autonomous Scheduler ──────────────────────────────────────────
STUDY_CHANNEL=@doctorwaleerat

# ── Video Processing ──────────────────────────────────────────────
WHISPER_MODEL=large-v3
FFMPEG_PATH=ffmpeg
OUTPUT_DIR=./output
WHISPERCUT_DATA_DIR=/tmp/whispercut
