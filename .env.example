# ── AI Providers ─────────────────────────────────────────────────
# OpenRouter (v1 — analyze, cut, caption, feedback)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Gemini (v2 — study, clone, feedback with style template)
GEMINI_API_KEY=your-gemini-api-key

# ── Supabase (v1 — job queue, session storage) ────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Social Publishing (v1) ────────────────────────────────────────
# TikTok session cookie upload
TIKTOK_SESSION_ID=your-session-id

# ── Video Processing ──────────────────────────────────────────────
WHISPER_MODEL=large-v3
FFMPEG_PATH=ffmpeg
OUTPUT_DIR=./output

# ── Style Cloner (v2) ─────────────────────────────────────────────
# Working directory for downloaded videos, analysis, and clones
WHISPERCUT_DATA_DIR=/tmp/tiktok-clone

# ── Optional: Local AI (Ollama) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
