# ── AI Providers ─────────────────────────────────────────────────
# OpenRouter (v1 — analyze, cut, caption, feedback)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Gemini (v2 — study, clone, QA gate, scheduler weekly plan)
GEMINI_API_KEY=your-gemini-api-key

# ── MiniMax TTS — Dr.Gwang Cloned Voice ───────────────────────────
# Get API key: https://www.minimax.io → API Keys
# Get Voice ID: https://www.minimax.io/audio/text-to-speech → My Voices
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id
# Voice ID for your cloned voice (find in "My Voices" page)
MINIMAX_VOICE_ID=Dr.Gwang

# ── Supabase (coordinator DB — free tier) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ── Social Publishing ─────────────────────────────────────────────
# TikTok
TIKTOK_SESSION_ID=your-session-id
TIKTOK_ACCOUNT_ID=your-tiktok-account-id

# Instagram / Facebook (Meta)
IG_ACCOUNT_ID=your-instagram-account-id
FB_PAGE_ID=your-facebook-page-id

# YouTube — rotate multiple Google Cloud projects to bypass 6/day quota
# Comma-separated list: project1,project2,project3
YT_CHANNEL_ID=your-youtube-channel-id
YT_PROJECT_IDS=your-gcp-project-1,your-gcp-project-2

# ── Autonomous Scheduler ──────────────────────────────────────────
# TikTok channel to study for style template
STUDY_CHANNEL=@doctorwaleerat

# ── Video Processing ──────────────────────────────────────────────
WHISPER_MODEL=large-v3
FFMPEG_PATH=ffmpeg
OUTPUT_DIR=./output

# ── Style Cloner (v2) ─────────────────────────────────────────────
# Working directory for downloaded videos, analysis, and clones
WHISPERCUT_DATA_DIR=/tmp/whispercut

# ── Optional: Local AI (Ollama) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
